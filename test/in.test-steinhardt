#variable seed equal 42
#variable METAD_PLUGIN_PATH getenv METAD_PLUGIN_PATH
variable temp_eq equal 2000
variable temp equal 600

# --- 1. 检查是否存在 restart.metad ---
shell "if [ -f restart.latest ]; then echo 'variable has_restart equal 1' > check.lmp; else echo 'variable has_restart equal 0' > check.lmp; fi"
include check.lmp
shell rm check.lmp

# --- 2. 基础环境设置 ---
# 简单 2-D 玩具体系，用 Lennard-Jones
units metal
atom_style atomic
boundary p p p
#newton off
# 加载插件
plugin load ${METAD_PLUGIN_PATH}/fix_crystallize_plugin.so

# --- 3. 逻辑跳转：如果是从文件启动 ---
if "${has_restart} == 1" then "jump SELF skip_equilibration"

# ----------------- 正常启动流程 (Normal/Liquidus) -----------------
lattice fcc 3.85
# lattice bcc 3.85
region box block 0 10 0 10 0 10
# region box block 0 20 0 20 0 20
# region box block 0 5 0 5 0 5
create_box 1 box
create_atoms 1 box

mass 1 39.95
pair_style meam
pair_coeff * * potential_testlib/library.meam Al potential_testlib/Al.meam Al

# region center_sphere sphere 5.0 5.0 5.0 3.0
# group zero_group region center_sphere
group zero_group region box
# group zero_group id 1 1000 5000

timestep 0.001
velocity all create ${temp_eq} 42
#velocity all create 0 42

fix             1 all npt  temp ${temp} ${temp} 0.1 iso 1 1 1
thermo 10
thermo_style custom step temp epair etotal press
dump normal all atom 10 dump.normal.lammpstrj
run 50000
# run 1
unfix     1
undump normal
write_restart restart.normal

# fix             1 all npt  temp ${temp_eq} ${temp_eq} 0.1 iso 1 1 1
fix             1 all nvt  temp ${temp_eq} ${temp_eq} 0.1
thermo 10
thermo_style custom step temp epair etotal press
dump liquidus all atom 10 dump.liquidus.lammpstrj
run 500000
# run 1
unfix     1

# fix             1 all npt  temp ${temp} ${temp} 0.1 iso 1 1 1
fix             1 all nvt  temp ${temp} ${temp} 0.1
run 5000
# run 1
unfix     1
undump liquidus

write_restart restart.liquidus
shell ln -sf restart.liquidus restart.latest


# --- 4. 跳转标签 ---
label skip_equilibration

if "${has_restart} == 1" then "read_restart restart.latest"

pair_style meam
pair_coeff * * potential_testlib/library.meam Al potential_testlib/Al.meam Al

# region metad_box block  xlo xhi ylo yhi zlo zhi
# region center_sphere sphere 5.0 5.0 5.0 3.0
# group metad_group region center_sphere
# group metad_group region metad_box
# group metad_group id 1 1000 5000
group metad_group union all

variable group_atoms equal count(metad_group)
variable actual_height equal "0.01 * v_group_atoms"
# 调用 metad fix：fix ID group metad sigma height biasf pace cv_dim nbin_num continue(bool)
# fix metad all metad GAUSSIAN 0.01 0.005 10.0 &
#                     PACE 10 &
#                     RECORD FILE_NAME rec.log REC_PACE 1 &
#                     CAL NAME Q6 STEINH Q 6 metad_group cutoff_r 4.5 cutoff_Natoms 18 &
#                     CAL NAME Q4 STEINH Q 4 metad_group cutoff_r 3.9 cutoff_Natoms 12 &
#                     SIMBOL v1 Q6.AVE &
#                     SIMBOL v2 Q4.AVE &
#                     CV_dim 1 &
#                     DIM 1 0 1 1000 "v1" &
#                     METAD_RESTART 1 &
#                     WT 0
fix metad all metad GAUSSIAN 0.01 0.5 10.0 &
                    PACE 10 &
                    RECORD FILE_NAME rec.log REC_PACE 1 &
                    CAL NAME Q6 STEINH Q 6 metad_group cutoff_r 3.8 cutoff_Natoms 18 &
                    CAL NAME Q4 STEINH Q 4 metad_group cutoff_r 3.8 cutoff_Natoms 18 &
                    SIMBOL v1 Q6.AVE &
                    SIMBOL v2 Q4.AVE &
                    CV_dim 1 &
                    DIM 1 0 1 1000 "(v1*2+v2)/3" &
                    METAD_RESTART 1 &
                    WT 0
fix             1 all nvt  temp ${temp} ${temp} 0.1

thermo 10
thermo_style custom step temp epair etotal press
dump 1 all atom 100 dump.metad.lammpstrj

# ----------------- 循环运行与软链接维护 -----------------
# 采用循环 run，每隔一定步数（如 10000 步）保存一次 restart 并更新软链接
# variable a loop 300 # 3,000,000 / 10,000
# label run_loop
    # run 10
    run 1000000
    
    # 保存带步数的 restart
    write_restart restart.metad
    
    # 执行 shell 命令更新软链接
    # 保持 restart.latest 始终指向最新的二进制 restart
    # 假设你的插件会自动更新 restart.metad 文件
    shell ln -sf restart.metad restart.latest
    
    # next a
# jump SELF run_loop
